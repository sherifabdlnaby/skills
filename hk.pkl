// hk.pkl — git hooks for hk. See skills/mise-fy/references/hk.md.
// Pin matches `hk` in mise.toml; both URLs must match. `hk init` regenerates.
amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

// Anchor for branch-scoped checks (--pr and the pushGates' base). Keep in sync with
// the base default in mise.toml's version:check task.
default_branch = "origin/main"

// Repo-wide ignores — committed paths only (.gitignore is already honored). Per-step `exclude` stacks on top.
local commonIgnores =
  List(
    "**/vendor/**",
    "**/generated/**",
    "**/*.min.*",
  )

// Gates by moment; each step lives in exactly one tier, hooks below only compose tiers.
// `check` mounts the union — the repo's full contract and the only hook CI runs.

// Commit gates — run on every commit: file-scoped, fast, auto-fixable.
local commitGates: Mapping<String, Step> = new Mapping<String, Step> {
  // formatting
  ["ruff-format"] = Builtins.ruff_format // python (skills/git/scripts/*.py)
  ["ruff"] = Builtins.ruff // python lint
  ["pkl-format"] = Builtins.pkl_format // pkl formatter (hk.pkl)
  ["pkl"] = Builtins.pkl // pkl validate (`pkl eval`)
  ["rumdl"] = Builtins.rumdl // markdown lint + format; table cell-alignment — config in rumdl.toml
  ["taplo"] = Builtins.taplo // TOML lint + format
  ["yamllint"] = Builtins.yamllint // YAML structure only — cosmetic rules off in .yamllint
  ["mise"] = Builtins.mise // validate mise.toml

  // spelling — accepted words / excludes live in typos.toml
  ["typos"] = Builtins.typos // source-code spell checker

  // dead links — offline (local/relative links only); see lychee.toml
  ["lychee"] = Builtins.lychee

  // GitHub Actions
  ["actionlint"] = Builtins.actionlint // workflow syntax
  ["zizmor"] = Builtins.zizmor // workflow security
  // pinact needs a GitHub token for tag→SHA resolution (CI: $GITHUB_TOKEN; local: gh auth).
  // Prepend onto the builtin commands so flags stay in sync. See mise-fy references/hk.md.
  ["pinact"] = (Builtins.pinact) {
    check_diff =
      "PINACT_GITHUB_TOKEN=\"${GITHUB_TOKEN:-$(gh auth token 2>/dev/null || true)}\" "
        + Builtins.pinact.check_diff
    fix =
      "PINACT_GITHUB_TOKEN=\"${GITHUB_TOKEN:-$(gh auth token 2>/dev/null || true)}\" "
        + Builtins.pinact.fix
  }

  // safety / hygiene
  ["betterleaks"] = Builtins.betterleaks // secret scanning — allowlist in .betterleaks.toml
  ["detect-private-key"] = Builtins.detect_private_key // block committed private keys
  ["newlines"] = Builtins.newlines // trailing newline
  ["trailing-whitespace"] = Builtins.trailing_whitespace // strip trailing whitespace
  ["mixed-line-ending"] = Builtins.mixed_line_ending // normalize CRLF/LF
  ["check-added-large-files"] = Builtins.check_added_large_files // block large blobs (>500KB default)
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["check-byte-order-marker"] = Builtins.byte_order_marker
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs
  ["check-symlinks"] = Builtins.check_symlinks // catch broken symlinks
}

// Push gates — run before a push: slower or branch-scoped checks that would drag the commit loop.
// Logic lives in mise tasks (runnable standalone, identical in CI); steps here only route to them.
local pushGates: Mapping<String, Step> = new Mapping<String, Step> {
  // Stale-marketplace guard: shipped plugin content must ride a manifest version bump.
  // The glob decides when the question is worth asking; the task answers by diffing vs
  // default_branch. Keep the glob in sync with the task's content/manifest lists.
  ["version-bump"] {
    glob = List("skills/**", "hooks/**", ".claude-plugin/*", ".cursor-plugin/*")
    check = "mise run version:check"
  }
}

exclude = commonIgnores

hooks {
  // `hk check` / `mise run check` — the union: everything this repo enforces, and the only
  // hook CI runs. Read-only; `--fix` applies. (No ["fix"] hook on purpose — `hk fix` errors,
  // shunting to the one blessed entry point; a fix hook would be a second mapping to keep in sync.)
  ["check"] {
    stage = false // `--fix` fixes the tree only; outside a commit, nothing touches the index
    steps {
      ...commitGates
      ...pushGates
    }
  }

  // `git commit` (staged) — commit gates only; fix inline. `stash` makes tools judge (and fix)
  // the staged snapshot, not the working tree — without it, partially-staged files get fixes
  // computed on (and re-staged with) unstaged hunks.
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = commitGates
  }

  // `git push` — push gates only (every commit already passed the commit gates). Best-effort
  // locally (`--no-verify` skips); CI's union run is the authoritative gate.
  ["pre-push"] {
    steps = pushGates
  }

  // Commit message ({{commit_msg_file}}) — no-op.
  ["commit-msg"] {
    steps {
    // ["conventional-commit"] = Builtins.check_conventional_commit
    }
  }
}
